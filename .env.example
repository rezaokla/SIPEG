################################################################################
# SIPEG (Sistem Informasi Pegawai Kementerian) - Environment Configuration
# Salin file ini menjadi .env dan sesuaikan nilai sesuai environment Anda
################################################################################

################################################################################
# APP CONFIGURATION
################################################################################

# Nama aplikasi
APP_NAME="Pegawaiku"

# Environment (local, staging, production)
APP_ENV=local

# Debug mode (true untuk development, false untuk production)
APP_DEBUG=true

# Application URL (sesuaikan dengan domain/IP Anda)
APP_URL=http://localhost:8000

# Application Key (generate dengan: php artisan key:generate)
# PENTING: Harus diganti setelah instalasi!
APP_KEY=base64:KLUw/NckQubGJZoXvsnc41zwjTSlbebDygs8ExwupFE=

# Timezone
APP_TIMEZONE=Asia/Jakarta

# Locale
APP_LOCALE=id

################################################################################
# DATABASE CONFIGURATION
################################################################################

# Database Driver (mysql, pgsql, sqlite, sqlsrv)
DB_CONNECTION=mysql

# Database Host
DB_HOST=127.0.0.1

# Database Port
DB_PORT=3306

# Database Name
DB_DATABASE=pegawaiku

# Database Username
DB_USERNAME=root

# Database Password (kosongkan jika tidak ada password)
DB_PASSWORD=

# MySQL Character Set dan Collation
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

################################################################################
# CACHE CONFIGURATION
################################################################################

# Cache Driver (file, database, redis, memcached, array, null)
CACHE_DRIVER=file

# Cache TTL (dalam detik)
CACHE_TTL=600

################################################################################
# SESSION CONFIGURATION
################################################################################

# Session Driver (file, cookie, database, memcached, redis, array)
SESSION_DRIVER=file

# Session Lifetime (dalam menit)
SESSION_LIFETIME=120

# Session Encryption
SESSION_ENCRYPT=false

################################################################################
# QUEUE CONFIGURATION
################################################################################

# Queue Driver (sync, database, beanstalkd, sqs, redis, null)
# Gunakan 'database' atau 'redis' untuk production email queuing
QUEUE_CONNECTION=sync

################################################################################
# MAIL CONFIGURATION
################################################################################

# Mail Driver (smtp, mailgun, postmark, sendgrid, sendmail, array, log)
MAIL_MAILER=smtp

# Mail Host (SMTP server)
MAIL_HOST=smtp.mailtrap.io

# Mail Port (587 untuk TLS, 465 untuk SSL)
MAIL_PORT=2525

# Mail From Address
MAIL_FROM_ADDRESS=noreply@pegawaiku.local

# Mail From Name
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Username
MAIL_USERNAME=

# SMTP Password
MAIL_PASSWORD=

# SMTP Encryption (tls, ssl, null)
MAIL_ENCRYPTION=tls

################################################################################
# BROADCAST CONFIGURATION
################################################################################

# Broadcast Driver (pusher, ably, null)
BROADCAST_DRIVER=log

################################################################################
# LOGGING CONFIGURATION
################################################################################

# Log Channel (single, daily, stack, syslog, errorlog, null)
LOG_CHANNEL=stack

# Log Level (debug, info, notice, warning, error, critical, alert, emergency)
LOG_LEVEL=debug

################################################################################
# PAGINATION
################################################################################

# Items per page untuk list views
PAGINATION_PER_PAGE=15

################################################################################
# APPLICATION SECURITY
################################################################################

# Trusted Proxies (jika di balik reverse proxy/load balancer)
# TRUSTED_PROXIES=

# Trusted Hosts
# TRUSTED_HOSTS=

# CSRF Token Configuration
CSRF_TOKEN_REGENERATE=true

# Password Policy
# Gunakan regex untuk enforce password complexity
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=false

# Login Throttle (attempts, minutes)
LOGIN_MAX_ATTEMPTS=5
LOGIN_THROTTLE_MINUTES=15

################################################################################
# AUTHENTICATION & AUTHORIZATION
################################################################################

# Guard Driver (web, api)
AUTH_GUARD=web

# Session Guard
SESSION_GUARD=web

# Default Password Hash Driver (bcrypt, argon2id, argon2)
HASHING_DRIVER=bcrypt

################################################################################
# OPTIONAL: EXTERNAL SERVICES
################################################################################

# Google Analytics (jika menggunakan analytics)
# GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking (untuk production error monitoring)
# SENTRY_LARAVEL_DSN=

# AWS S3 (jika file storage ke S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

################################################################################
# REDIS CONFIGURATION (Optional)
################################################################################

# Hanya diperlukan jika menggunakan Redis untuk cache/session/queue

# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_CACHE_DB=1
# REDIS_SESSION_DB=2
# REDIS_QUEUE_DB=3

################################################################################
# NOTES FOR DEVELOPMENT
################################################################################

# 1. Untuk DEVELOPMENT (local):
#    - APP_ENV=local
#    - APP_DEBUG=true
#    - Gunakan database lokal (localhost)
#    - MAIL_MAILER=log (print ke storage/logs)

# 2. Untuk STAGING/DEMO:
#    - APP_ENV=staging
#    - APP_DEBUG=false
#    - Gunakan database staging
#    - MAIL_MAILER=smtp dengan test credentials
#    - Session/Cache pakai database atau redis

# 3. Untuk PRODUCTION:
#    - APP_ENV=production
#    - APP_DEBUG=false
#    - APP_URL=https://domain-asli.com (HTTPS!)
#    - Generate APP_KEY baru: php artisan key:generate
#    - Database dengan proper backups
#    - MAIL_MAILER=smtp dengan service provider (Mailgun, SendGrid, dll)
#    - QUEUE_CONNECTION=redis atau database (bukan sync)
#    - SESSION_DRIVER=database atau redis
#    - CACHE_DRIVER=redis
#    - Gunakan Sentry atau error tracking lainnya

################################################################################
# QUICK START CHECKLIST
################################################################################

# 1. Copy file ini:
#    cp .env.example .env

# 2. Generate APP_KEY:
#    php artisan key:generate

# 3. Setup database:
#    - Buat database MySQL: CREATE DATABASE pegawaiku;
#    - Update DB_* variables di .env
#    - Jalankan: php artisan migrate --seed

# 4. Jalankan development server:
#    php artisan serve

# 5. Login dengan credentials default (diubah setelah first login!):
#    Email: admin@pegawaiku.local
#    Password: password123

################################################################################
